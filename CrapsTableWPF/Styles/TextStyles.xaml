<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!--Body style-->
    <!--inherit from the implicit style using e.g. BasedOn="{StaticResource {x:Type TextBlock}}"-->
    <!--without this, a control's style will be replaced, not composed of multiple styles with inherited properties-->
    <Style x:Key="BodyTextStyle" 
           TargetType="TextBlock" 
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <!--<Setter Property="FontFamily" Value="Ubuntu"/>-->
        <!--<Setter Property="FontSize"   Value="14"      />-->
        <!--<Setter Property="Foreground" Value="Black" />-->
    </Style>

    <!--Heading styles-->
    <Style x:Key="TitleTextStyle" 
           TargetType="TextBlock" 
           BasedOn="{StaticResource BodyTextStyle}">
        <!--<Setter Property="FontSize" Value="18"/>-->
        <Setter Property="FontWeight"               Value="Bold"/>
    </Style>

    <!--POP-UP WINDOWS / DIALOGS-->
    <!--Pop-up window/dialog TEXT styles-->
    <Style x:Key="PopUpWindowBodyTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="HorizontalAlignment"      Value="Center"/>
        <Setter Property="VerticalAlignment"        Value="Center"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="Foreground"               Value="{StaticResource BrightTextBrush}"/>
    </Style>

    <!--Pop-up window/dialog BUTTON text styles-->
    <Style x:Key="PopUpWindowButtonTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="HorizontalAlignment"      Value="Center"/>
        <Setter Property="VerticalAlignment"        Value="Center"/>
        <Setter Property="Foreground"               Value="{StaticResource PrimaryTextBrush}"/>
    </Style>

    <!--Pop-up window/dialog TEXTBOX styles-->
    <Style x:Key="PopUpWindowTextBoxTextStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Margin"                   Value="10,30,10,30"/>
        <Setter Property="Padding"                  Value="6"/>
    </Style>

    <!--MAIN WINDOW-->
    <Style x:Key="MainWindowNormal"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="Foreground"               Value="{StaticResource BrightTextBrush}"/>
        <Setter Property="HorizontalAlignment"      Value="Center"/>
        <Setter Property="VerticalAlignment"        Value="Center"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="FontSize"                 Value="24"/>
    </Style>
    
    <!--Main window player slot text styles-->
    <Style x:Key="PlayerBodyTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="HorizontalAlignment"      Value="Center"/>
        <Setter Property="VerticalAlignment"        Value="Center"/>
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="FontSize"                 Value="24"/>
    </Style>

    <Style x:Key="PlayerHeadingStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource PlayerBodyTextStyle}">
        <Setter Property="FontWeight"               Value="Bold"/>
    </Style>

    <Style x:Key="PlayerSlotIndexHeadingStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource PlayerHeadingStyle}">
        <Setter Property="HorizontalAlignment"      Value="Left"/>
        <Setter Property="VerticalAlignment"        Value="Top"/>
        <Setter Property="Padding"                  Value="10,10,0,0"/>
    </Style>

    
    <!--Main window button TextBlock styles-->
    <Style x:Key="MainWindowButtonTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="Margin"                   Value="4"/>
        <Setter Property="FontSize"                 Value="24"/>
    </Style>

    <Style x:Key="MainWindowButtonCloseTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="Margin"                   Value="0,0,0,6"/>
        <Setter Property="FontSize"                 Value="24"/>
        <Setter Property="FontWeight"               Value="Bold"/>
        <Setter Property="TextAlignment"            Value="Center"/>
        <Setter Property="HorizontalAlignment"      Value="Center"/> 
        <Setter Property="VerticalAlignment"        Value="Center"/>
    </Style>

    <!--Game Event Feed Styles-->
    <Style x:Key="GameEventFeedNormalTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontSize"                 Value="24"/>
        <Setter Property="Margin"                   Value="0"/>
        <Setter Property="Padding"                  Value="0"/>
    </Style>


    <!--<Style x:Key="GameEventFeedDiceRollTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameEventFeedNormalTextBlockStyle}">
        <Setter Property="Foreground"               Value="{StaticResource PrimaryTextBrush}"/>
    </Style>-->

    <!--<Style x:Key="GameEventFeedOutcomeTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource GameEventFeedNormalTextBlockStyle}">
        <Setter Property="Foreground"               Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Margin"                   Value="20,0,0,0"/>
    </Style>-->

    <!--Main window BET TextBlock styles-->
    <Style x:Key="BetTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextStyle}">
        <Setter Property="FontSize"                 Value="14"/>
        <Setter Property="Margin"                   Value="0,0,0,2.1"/>
        <Setter Property="Padding"                  Value="0"/>
        <Setter Property="HorizontalAlignment"      Value="Center"/>
        <Setter Property="VerticalAlignment"        Value="Center"/>
    </Style>
</ResourceDictionary>