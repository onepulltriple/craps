<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--border styles-->
    <!--Border is a visual container, which controls how things look-->
    <Style x:Key="NoBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Background"           Value="Transparent"/>
    </Style>

    <Style x:Key="NoClippingBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource NoBorderStyle}">
        <Setter Property="ClipToBounds"         Value="False"/>
    </Style>

    <Style x:Key="RoundedBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="2"/>
        <Setter Property="CornerRadius"         Value="10"/>
        <Setter Property="Padding"              Value="0"/>
        <Setter Property="ClipToBounds"         Value="True"/>
    </Style>

    <Style x:Key="MainWindowPlayerSlotBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="Height"               Value="200"/>
        <Setter Property="Width"                Value="300"/>
    </Style>

    <Style x:Key="GameEventFeedRoundedBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="Padding"              Value="10,6,10,6"/>
    </Style>

    <Style x:Key="BetBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="ClipToBounds"         Value="False"/>
        <Setter Property="Width"                Value="40"/>
        <Setter Property="Height"               Value="40"/>
    </Style>


    <Style x:Key="GlowingBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="ClipToBounds"         Value="False"/>
        <Setter Property="Effect"               Value="{x:Null}"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCurrentPlayer}"
                         Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="GlowStoryBoard">
                        <Storyboard RepeatBehavior="Forever"
                                    AutoReverse="True">
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                From="0.3"
                                To="1.0"
                                Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="GlowStoryBoard"/>
                </DataTrigger.ExitActions>

                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Lime"
                                          BlurRadius="30"
                                          ShadowDepth="0"
                                          Opacity="0.3"/>
                    </Setter.Value>
                </Setter>

            </DataTrigger>
        </Style.Triggers>
    </Style>




    <!--panel styles-->
    <!--panels are layout containers that lay out their children, i.e. control where things go-->
    <!--e.g. StackPanel, Grid, WrapPanel, DockPanel, Canvas-->
    <!--these do not inherit from Border!-->

    <!--sets the default StackPanel properties globally-->
