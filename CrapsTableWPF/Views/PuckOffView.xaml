<UserControl x:Class="CrapsTableWPF.Views.PuckOffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:CrapsTableWPF.Views"
             xmlns:viewmodels="clr-namespace:CrapsTableWPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignWidth="100" d:DesignHeight="100" 
             Width="100" Height="100"
             >
    <Border Style="{StaticResource NoBorderStyle}">
        <!-- SVG in background, scales to window -->
        <Viewbox 
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <svg:SvgViewbox Source="puckOff.svg"
                        IsHitTestVisible="False"
                        MaxWidth ="{Binding ActualWidth,  RelativeSource={RelativeSource AncestorType=Window}}"
                        MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Viewbox>
    </Border>
</UserControl>
