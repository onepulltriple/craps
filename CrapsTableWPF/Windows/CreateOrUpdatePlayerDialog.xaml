<Window x:Class="CrapsTableWPF.Windows.CreateOrUpdatePlayerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF.Windows"
        xmlns:viewmodels="clr-namespace:CrapsTableWPF.ViewModels"
        mc:Ignorable="d"
        Title="Manage player"
        Width="500" Height="400" MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource PopUpWindowOrDialogStyle}"
        d:DataContext="{d:DesignInstance Type=viewmodels:CreateOrUpdatePlayerDialogViewModel}"
        >
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.6*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--upper section-->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="Player name:"/>
        <TextBox Name="TB00"
                 Grid.Row="0" Grid.Column="1"
                 Style="{StaticResource PopUpWindowTextBoxTextStyle}"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="Purse:"/>
        <TextBox Name="TB01"
                 Grid.Row="1" Grid.Column="1"
                 Style="{StaticResource PopUpWindowTextBoxTextStyle}"
                 Text="{Binding Purse, UpdateSourceTrigger=PropertyChanged}"/>

        <!--middle section-->
        <TextBlock Name="UIErrorMessage"
                   Grid.Row="2" Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding HasErrors,
                   Converter={StaticResource BoolToVisibilityConverter}}"
                   />
         
        <!--lower section-->
        <Button Grid.Row="3" Grid.Column="0"
                Click="QuitButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="Quit"/>
        </Button>
        <Button Grid.Row="3" Grid.Column="1"
                Command="{Binding OKButtonCommand}"
                >
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="OK"
                       />
        </Button>

    </Grid>

    <Window.InputBindings>
        <KeyBinding Key="Enter"
                    Command="{Binding OKButtonCommand}"/>
    </Window.InputBindings>
</Window>
