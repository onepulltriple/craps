<Window x:Class="CrapsTableWPF.Windows.CreateOrUpdateBetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF.Windows"
        mc:Ignorable="d"
        Title="Edit bet"
        Width="500" Height="500" MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource PopUpWindowOrDialogStyle}"
        >
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.6*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--upper section-->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="{Binding Name}"
                   d:Text="Bet name and owner"/>
        
        <!--<TextBlock Grid.Row="1" Grid.Column="0"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="some other property:"/>
        <TextBox Name="TB00"
                Grid.Row="1" Grid.Column="1"
                Style="{StaticResource PopUpWindowTextBoxTextStyle}"
                KeyDown="TB00KeyDownHandler"
                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>-->

        <TextBlock Grid.Row="2" Grid.Column="0"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="Commitment:"/>
        <TextBox Name="TB01"
                Grid.Row="2" Grid.Column="1"
                Style="{StaticResource PopUpWindowTextBoxTextStyle}"
                KeyDown="TB01KeyDownHandler"
                Text="{Binding Commitment, UpdateSourceTrigger=PropertyChanged}"/>

        <!--middle section-->
        <TextBlock Name="UIErrorMessage"
                Grid.Row="3" Grid.Column="0"
                Grid.ColumnSpan="2"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text=""
                />

        <!--lower section-->
        <Button Grid.Row="4" Grid.Column="0"
            Click="QuitButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                    Text="Quit"/>
        </Button>
        <Button Grid.Row="4" Grid.Column="1"
            Click="OKButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                    Text="OK"/>
        </Button>
    </Grid>
</Window>
