<Window x:Class="CrapsTableWPF.Windows.SetCrapsTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF.Windows"
        mc:Ignorable="d"
        Title="SetCrapsTableWindow" 
        Width="500" Height="300" 
        MinWidth="500" MinHeight="300"
        Style="{StaticResource PopUpWindowOrDialogStyle}"
        >
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="1.0*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--upper section-->
        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="Please set the table minimum:"/>
        
        <TextBox   Name="TB00"
                   Grid.Row="0" Grid.Column="1"
                   Style="{StaticResource PopUpWindowTextBoxTextStyle}"
                   KeyDown="TB00KeyDownHandler"/>

        <!--middle section-->
        <TextBlock Name="UIErrorMessage"
                   Grid.Row="1" Grid.Column="0" 
                   Grid.ColumnSpan="2"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text=""
                   />

        <!--lower section-->
        <Button Grid.Row="2" Grid.Column="0"
                Click="QuitButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="Quit"/>
        </Button>
        <Button Grid.Row="2" Grid.Column="1"
                Click="ProceedButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="Proceed"/>
        </Button>

    </Grid>
</Window>
