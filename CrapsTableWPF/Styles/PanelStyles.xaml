<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:styles="clr-namespace:CrapsTableWPF.Styles">

    <!--border styles-->
    <!--Border is a visual container, which controls how things look-->
    <Style x:Key="NoBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Background"           Value="Transparent"/>
    </Style>

    <Style x:Key="NoClippingBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource NoBorderStyle}">
        <Setter Property="ClipToBounds"         Value="False"/>
    </Style>

    <Style x:Key="RoundedBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="2"/>
        <Setter Property="CornerRadius"         Value="10"/>
        <Setter Property="Padding"              Value="0"/>
        <Setter Property="ClipToBounds"         Value="True"/>
    </Style>

    <Style x:Key="MainWindowPlayerSlotBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="Height"               Value="200"/>
        <Setter Property="Width"                Value="300"/>
    </Style>

    <Style x:Key="GameEventFeedRoundedBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="Padding"              Value="10,6,10,6"/>
    </Style>

    <Style x:Key="BetBorderStyle" 
           TargetType="Border"
           BasedOn="{StaticResource {x:Type Border}}">
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="ClipToBounds"         Value="False"/>
        <Setter Property="Width"                Value="40"/>
        <Setter Property="Height"               Value="40"/>
    </Style>

    <!--outer glow effect-->
    <Style x:Key="GlowingBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource RoundedBorderStyle}">
        <Setter Property="Background"           Value="Transparent"/>
        <Setter Property="ClipToBounds"         Value="False"/>
        <Setter Property="BorderThickness"      Value="10"/>
        <Setter Property="BorderBrush"          Value="Red"/>
        <Setter Property="CornerRadius"         Value="10"/>

        <!-- default (non-glowing state) -->
        <Setter Property="Effect"               Value="{x:Null}"/>

        <!--glowing state-->
        <Style.Resources>
            <DropShadowEffect x:Key="GlowEffect"
                              Color="Lime"
                              BlurRadius="30"
                              ShadowDepth="0"
                              Opacity="0.3"/>
        </Style.Resources>
        
        <Style.Triggers>
            <Trigger Property="styles:GlowBehavior.IsGlowing"
                     Value="True">
                
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Lime"
                                          BlurRadius="30"
                                          ShadowDepth="0"
                                          Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
                     
                <Trigger.EnterActions>
                    <!--<BeginStoryboard x:Name="GlowStoryBoard">-->
                        <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever"
                                    AutoReverse="True">
                            <DoubleAnimation
                                Storyboard.TargetProperty="Effect.Opacity"
                                From="0.3"
                                To="1.0"
                                Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>

                <!--<Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="GlowStoryBoard"/>
                </Trigger.ExitActions>-->

            </Trigger>

        </Style.Triggers>
    </Style>




    <!--panel styles-->
    <!--panels are layout containers that lay out their children, i.e. control where things go-->
    <!--e.g. StackPanel, Grid, WrapPanel, DockPanel, Canvas-->
    <!--these do not inherit from Border!-->

    <!--sets the default StackPanel properties globally-->
    <!--<Style TargetType="StackPanel">
        <Setter Property="Margin"               Value="4"/>
        <Setter Property="Orientation"          Value="Vertical"/>
    </Style>

    <Style x:Key="SpacedStackPanel"
           TargetType="StackPanel"
           BasedOn="{StaticResource {x:Type StackPanel}}">
        <Setter Property="Margin"               Value="10"/>
    </Style>-->
    
</ResourceDictionary>