<Window x:Class="CrapsTableWPF.CRUDWindowCrapsTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF"
        mc:Ignorable="d"
        Title="CRUDWindowCrapsTable" Height="200" Width="400">
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        
        <!--headline-->
        <Label Grid.Row="0" Grid.Column="0" FontSize="20" Margin="6" VerticalAlignment="Center">
            <TextBlock>
                Craps!!
            </TextBlock>
        </Label>
        <!--middle section-->
        <Label Grid.Row="1" Grid.Column="0" FontSize="12" Margin="6" VerticalAlignment="Center">
            <TextBlock>
                Welcome! Please set the table minimum:
            </TextBlock>
        </Label>
        <TextBox Grid.Row="1" Grid.Column="1" FontSize="12" Margin="6" VerticalAlignment="Center"/>
        <!--lower section-->
        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Button Name="QuitButton" Grid.Column="0" Content="Quit"    Click="QuitBottonClicked"/>
            <Button Name="ProcButton" Grid.Column="1" Content="Proceed" Click="ProcBottonClicked"/>



        </Grid>
    </Grid>
    
    
</Window>
