<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--global default font parameters-->
    <!--these are implicit styles that auto-apply by type-->
    <FontFamily x:Key="DefaultFont">
        Segoe UI
    </FontFamily>

    <!--font size is in device-independent units (DIP = 1/96th inch)-->
    <System:Double x:Key="DefaultFontSize" xmlns:System="clr-namespace:System;assembly=mscorlib">
        14
    </System:Double>
                          
    
    <!--text defaults-->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily"           Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"             Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Foreground"           Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="TextWrapping"         Value="Wrap"/>
        <Setter Property="Margin"               Value="0"/>
        <Setter Property="FontStyle"            Value="Normal"/>
        <Setter Property="FontWeight"           Value="Normal"/>
    </Style>

    <Style TargetType="Label" 
           BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="FontFamily"           Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"             Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Foreground"           Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>
    
    <!--panel defaults-->
    <Style TargetType="Border">
        <Setter Property="Background"           Value="{DynamicResource PrimaryPanelBackgroundBrush}"/>
        <Setter Property="BorderBrush"          Value="{DynamicResource PrimaryBorderBrush}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="CornerRadius"         Value="10"/>
        <Setter Property="Padding"              Value="0"/>
    </Style>
    
    <!--button defaults-->
    <Style TargetType="Button">
        <Setter Property="FontFamily"           Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"             Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Padding"              Value="2,2,2,2"/>
        <Setter Property="Margin"               Value="4"/>
        <Setter Property="Cursor"               Value="Hand"/>
    </Style>
    
    <!--input defaults-->
    <Style TargetType="TextBox">
        <Setter Property="FontFamily"           Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"             Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="Padding"              Value="4"/>
        <Setter Property="Margin"               Value="2"/>
        <Setter Property="IsTabStop"            Value="True"/>
    </Style>
    
</ResourceDictionary>