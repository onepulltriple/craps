<UserControl x:Class="CrapsTableWPF.Views.BetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:CrapsTableWPF.Views"
             xmlns:viewmodels="clr-namespace:CrapsTableWPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:BetViewModel}"
             d:DesignHeight="40" d:DesignWidth="40"
             Background="MediumPurple"
             >
    <Grid>
        <TextBlock
            Style="{StaticResource BetTextBlockStyle}"
            Text="{Binding Commitment}"
            d:Text="9999"/>
    </Grid>
</UserControl>
