<Window x:Class="CrapsTableWPF.Windows.SetCrapsTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF.Windows"
        mc:Ignorable="d"
        Title="SetCrapsTableWindow" 
        Width="500" Height="300" 
        MinWidth="500" MinHeight="300"
        Background="{StaticResource CasinoGreenBrush}"
        >
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--upper section-->
        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="Please set the table minimum:"/>
        
        <TextBox   Name="TB00"
                   Grid.Row="0" Grid.Column="1"
                   Margin="4,30,4,30"
                   Padding="6"
                   KeyDown="TB00KeyDownHandler"/>

        <!--middle section-->
        <TextBlock Name="UIErrorMessage"
                   Grid.Row="1" Grid.Column="0" 
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text=""
                   Margin="4"
                   Grid.ColumnSpan="2"/>

        <!--lower section-->
        <Button Grid.Row="2" Grid.Column="0"
                Content="Quit"
                Click="QuitButtonClicked"/>
        <Button Grid.Row="2" Grid.Column="1"
                Content="Proceed"
                Click="ProceedButtonClicked"/>

    </Grid>
</Window>
