<UserControl x:Class="CrapsTableWPF.Views.HardWayBetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:CrapsTableWPF.Views"
             xmlns:viewmodels="clr-namespace:CrapsTableWPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:HardWayBetViewModel}"
             Width="352" Height="100"
             >
    <Canvas Width="352" Height="100"
            Background="{x:Null}">
        
        <Border Canvas.Left="134" Canvas.Top="58"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[0], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[0]}"/>
        </Border>
        
        <Border Canvas.Left="90" Canvas.Top="58"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[1], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[1]}"/>
        </Border>
        
        <Border Canvas.Left="46" Canvas.Top="58"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[2], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[2]}"/>
        </Border>
        
        <Border Canvas.Left="2" Canvas.Top="58"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[3], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[3]}"/>
        </Border>

        
        <Border Canvas.Left="2" Canvas.Top="2"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[4], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[4]}"/>
        </Border>
        
        <Border Canvas.Left="46" Canvas.Top="2"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[5], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[5]}"/>
        </Border>
        
        <Border Canvas.Left="90" Canvas.Top="2"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[6], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[6]}"/>
        </Border>
        
        <Border Canvas.Left="134" Canvas.Top="2"
            Style="{StaticResource BetBorderStyle}"
            Visibility="{Binding BetSlotViewModels[7], Converter={StaticResource NullToVisibilityConverter}}"
            >
            <views:BetSlotView DataContext="{Binding BetSlotViewModels[7]}"/>
        </Border>

    </Canvas>
</UserControl>
