<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!--window styles-->
    <Style x:Key="MainWindowStyle"
        TargetType="Window"
           BasedOn="{StaticResource {x:Type Window}}">
        <Setter Property="Background"           Value="{StaticResource CasinoGreenBrush}"/>
        <Setter Property="Left"                 Value="100"/>
        <Setter Property="Top"                  Value="100"/>
    </Style>

    <Style x:Key="PopUpWindowOrDialogStyle"
        TargetType="Window"
           BasedOn="{StaticResource MainWindowStyle}">
    </Style>

</ResourceDictionary>