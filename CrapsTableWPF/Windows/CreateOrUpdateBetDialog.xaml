<Window x:Class="CrapsTableWPF.Windows.CreateOrUpdateBetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CrapsTableWPF.Windows"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:viewmodels="clr-namespace:CrapsTableWPF.ViewModels"
        mc:Ignorable="d"
        Title="Manage bet"
        Width="500" Height="500" MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource PopUpWindowOrDialogStyle}"
        d:DataContext="{d:DesignInstance Type=viewmodels:CreateOrUpdateBetDialogViewModel}"
        >
    <Grid Loaded="GridLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.6*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--top section-->
        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Grid.ColumnSpan="2"
                   Style="{StaticResource PopUpWindowBodyHeadingTextStyle}"
                   d:Text="Manage PlayerName's betInfo.Name bet"
                   Text="{Binding Heading}"/>

        <Grid Grid.Row="1" Grid.Column="0" 
              Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock 
                Grid.Row="0" Grid.Column="0"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="Count of units:"/>
            <xctk:IntegerUpDown 
                Grid.Row="1" Grid.Column="0"
                Value="{Binding CountOfUnitsToBet, Mode=TwoWay}"
                FontSize="24"
                Minimum="0"
                Maximum="10"
                />
                <!--ValueChanged="{Binding ValueChangedCommand}"-->

            <TextBlock 
                Grid.Row="0" Grid.Column="1"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="Cost per unit:"/>
            <TextBlock
                Grid.Row="1" Grid.Column="1"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                d:Text="bet.UnitOfBet"
                Text="{Binding UnitOfBet, UpdateSourceTrigger=PropertyChanged}"/>



            <TextBlock 
                Grid.Row="0" Grid.Column="3"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="Amount thrown:"/>
            <TextBox Name="TB00"
                Grid.Row="1" Grid.Column="3"
                Text="{Binding Commitment, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
        

        <!--middle section-->
        <TextBlock Name="UIErrorMessage"
                Grid.Row="3" Grid.Column="0"
                Grid.ColumnSpan="2"
                Style="{StaticResource PopUpWindowBodyTextStyle}"
                Text="{Binding ErrorMessage}"
                Visibility="{Binding HasErrors,
                Converter={StaticResource BoolToVisibilityConverter}}"
                />


        <!--<TextBlock Grid.Row="3" Grid.Column="0"
                   Style="{StaticResource PopUpWindowBodyTextStyle}"
                   Text="{Binding CountOfUnitsToBet, UpdateSourceTrigger=PropertyChanged}"
                   />-->


        
        <!--bottom section-->
        <Button Grid.Row="4" Grid.Column="0"
                Click="QuitButtonClicked">
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="Quit"/>
        </Button>
        <Button Grid.Row="4" Grid.Column="1"
                Command="{Binding OKButtonCommand}"
                >
            <TextBlock Style="{StaticResource PopUpWindowButtonTextStyle}"
                       Text="OK"/>
        </Button>
    </Grid>

    <Window.InputBindings>
        <KeyBinding Key="Enter"
                    Command="{Binding OKButtonCommand}"/>
    </Window.InputBindings>
</Window>
