<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="NewButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <!--<Setter Property="FontFamily" Value="Ubuntu"/>-->
    </Style>

    
    
    <Style x:Key="MainWindowButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}"
           >
        <Setter Property="Background"           Value="Transparent"/>
    </Style>

    <Style x:Key="MainWindowPlayerSlotButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource MainWindowButtonStyle}"
           >
        <Setter Property="BorderThickness"      Value="0"/>
    </Style>

    <Style x:Key="MainWindowCloseButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource MainWindowButtonStyle}"
           >
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="Width"                Value="40"/>
        <Setter Property="Height"               Value="40"/>
        <Setter Property="HorizontalAlignment"  Value="Right"/>
        <Setter Property="VerticalAlignment"    Value="Top"/>
    </Style>

</ResourceDictionary>