<Application x:Class="CrapsTableWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CrapsTableWPF"
             xmlns:infrastructure="clr-namespace:CrapsTableWPF.Infrastructure"
             StartupUri="Windows/SetCrapsTableWindow.xaml"
             >
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--ordering matters here!!-->
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Styles/NormalStyles.xaml"/>
                <ResourceDictionary Source="Styles/TextStyles.xaml"/>
                <ResourceDictionary Source="Styles/PanelStyles.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/WindowStyles.xaml"/>
                <ResourceDictionary Source="Styles/OtherControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!--provided by WPF-->
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            
            <!--custom-->
            <infrastructure:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
    
</Application>
